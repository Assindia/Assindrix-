<?xml version="1.0" encoding="UTF-8"?>
<X3D profile='Immersive' version='4.0'>
  <Scene>

    <Background skyColor='0.95 0.95 0.95'/>

    <Viewpoint position='1.5 1.3 2.5'
               orientation='1 0 0 -0.3'
               description='Gesamtansicht'/>
    <Viewpoint position='0 1 5'
           orientation='0 0 0 1'
           description='TEST'/>
    <!-- ========================= -->
    <!-- Grundplatte -->
    <!-- ========================= -->
    <Transform DEF='Grundplatte' translation='0 0.015 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.72 0.52 0.30'/>
        </Appearance>
        <!-- Radius 15 cm, Höhe 3 cm -->
        <Cylinder radius='0.15' height='0.03'/>
      </Shape>
    </Transform>

    <!-- Bohrung (nur sichtbar dargestellt) -->
    <Transform DEF='Bohrung' translation='0 0.0201 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.25 0.15 0.08'/>
        </Appearance>
        <!-- 28 mm = Radius 1.4 cm -->
        <Cylinder radius='0.014' height='0.02'/>
      </Shape>
    </Transform>

    <!-- ========================= -->
    <!-- Stange -->
    <!-- ========================= -->
    <Transform DEF='Stange' translation='0 0.77 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.80 0.65 0.45'/>
        </Appearance>
        <!-- 150 cm -->
        <Cylinder radius='0.014' height='1.5'/>
      </Shape>
    </Transform>

    <!-- ========================= -->
    <!-- Kranz -->
    <!-- ========================= -->

    <!-- Äußerer Ring -->
    <Transform DEF='KranzAussen'
               translation='0 1.45 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.15 0.55 0.20'/>
        </Appearance>
        <Cylinder radius='0.18' height='0.03'/>
      </Shape>
    </Transform>

    <!-- Inneres Loch -->
    <Transform DEF='KranzInnen'
               translation='0 1.451 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.95 0.95 0.95'/>
        </Appearance>
        <Cylinder radius='0.12' height='0.032'/>
      </Shape>
    </Transform>

    <!-- ========================= -->
    <!-- Bänder -->
    <!-- ========================= -->

    <Transform DEF='BandLinks'
               translation='-0.08 1.52 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.85 0.85 0.85'/>
        </Appearance>
        <Box size='0.01 0.18 0.002'/>
      </Shape>
    </Transform>

    <Transform DEF='BandRechts'
               translation='0.08 1.52 0'>
      <Shape>
        <Appearance>
          <Material diffuseColor='0.85 0.85 0.85'/>
        </Appearance>
        <Box size='0.01 0.18 0.002'/>
      </Shape>
    </Transform>

  </Scene>
</X3D>
