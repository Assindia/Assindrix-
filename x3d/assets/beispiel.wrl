#VRML V2.0 utf8
NavigationInfo {type ["EXAMINE", "WALK", "FLY", "NONE"]}      
DEF DREHEN Transform {
   children [
      Shape {
         appearance DEF GELB Appearance {
            material Material {
               diffuseColor .89 .73 .34
			   specularColor .27 .13 .13
			   ambientIntensity .0933
			   shininess .31
            }
         }
         geometry Box { }
      }

      DEF CLOCK TimeSensor {
          cycleInterval 5.0
	  loop TRUE
      }

      DEF PFAD OrientationInterpolator {
          # Runde drehen
          key [ 0.0, 0.50, 1.0 ]
          keyValue [
              0.2 1.0 0.0  0.0,
              0.2 1.0 0.0  3.14,
              0.2 1.0 0.0  6.28
          ]
      } #PFAD
   ] #children
} #transform

ROUTE CLOCK.fraction_changed TO PFAD.set_fraction
ROUTE PFAD.value_changed     TO DREHEN.set_rotation
   